{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "skipLibCheck": true,
    "jsx": "react-jsx",
    "baseUrl": ".",
    "paths": {
      "@flipova/foundation":        ["../../../foundation"],
      "@flipova/foundation/*":      ["../../../foundation/*"],
      "@flipova/studio-core":       ["../core/src/index.ts"],
      "@flipova/studio-core/*":     ["../core/src/*"]
    },
    "typeRoots": [
      "../../../node_modules/@types"
    ]
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"]
}
