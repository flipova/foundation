{
  "name": "@flipova/foundation",
  "version": "1.5.0",
  "description": "Design tokens, theming system, and layout primitives for React Native (iOS, Android, Web)",
  "author": "Flipova",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/flipova/foundation.git"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./tokens": {
      "types": "./dist/tokens/index.d.ts",
      "import": "./dist/tokens/index.mjs",
      "require": "./dist/tokens/index.js"
    },
    "./theme": {
      "types": "./dist/theme/index.d.ts",
      "import": "./dist/theme/index.mjs",
      "require": "./dist/theme/index.js"
    },
    "./layout": {
      "types": "./dist/layout/index.d.ts",
      "import": "./dist/layout/index.mjs",
      "require": "./dist/layout/index.js"
    },
    "./config": {
      "types": "./dist/config/index.d.ts",
      "import": "./dist/config/index.mjs",
      "require": "./dist/config/index.js"
    },
    "./studio": {
      "types": "./dist/studio/index.d.ts",
      "import": "./dist/studio/index.mjs",
      "require": "./dist/studio/index.js"
    }
  },
  "bin": {
    "flipova-studio": "./dist/studio/cli/index.js"
  },
  "files": [
    "dist",
    "studio/app/dist",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "npm run build:studio && npm run build:foundation",
    "build:foundation": "tsup",
    "build:studio": "cd studio/app && npx expo export --platform web --output-dir dist",
    "dev": "tsup --watch",
    "dev:studio": "cd studio/app && npx expo start --web --port 4201",
    "typecheck": "tsc --noEmit",
    "release": "npm run build && npm run typecheck && changeset publish",
    "version": "changeset version",
    "prepublishOnly": "npm run build && npm run typecheck"
  },
  "peerDependencies": {
    "expo-camera": ">=15.0.0",
    "expo-haptics": ">=13.0.0",
    "expo-linear-gradient": ">=12.0.0",
    "expo-navigation-bar": ">=3.0.0",
    "expo-status-bar": ">=2.0.0",
    "lucide-react-native": ">=0.300.0",
    "react": ">=18.0.0",
    "react-native": ">=0.73.0",
    "react-native-gesture-handler": ">=2.0.0",
    "react-native-reanimated": ">=3.0.0",
    "react-native-safe-area-context": ">=4.0.0"
  },
  "peerDependenciesMeta": {
    "expo-linear-gradient": {
      "optional": true
    },
    "expo-haptics": {
      "optional": true
    },
    "expo-status-bar": {
      "optional": true
    },
    "expo-navigation-bar": {
      "optional": true
    },
    "react-native-gesture-handler": {
      "optional": true
    },
    "react-native-reanimated": {
      "optional": true
    },
    "react-native-safe-area-context": {
      "optional": true
    },
    "lucide-react-native": {
      "optional": true
    },
    "expo-camera": {
      "optional": true
    }
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.6.0",
    "@changesets/cli": "^2.30.0",
    "@types/express": "^5.0.6",
    "@types/qrcode": "^1.5.5",
    "@types/react": "^19.0.0",
    "@types/react-native": "^0.73.0",
    "@types/ws": "^8.18.1",
    "expo-camera": "^55.0.13",
    "expo-haptics": "^55.0.11",
    "expo-linear-gradient": "^12.0.0",
    "expo-navigation-bar": "^55.0.10",
    "expo-status-bar": "^55.0.5",
    "fast-check": "^4.6.0",
    "lucide-react-native": "^1.7.0",
    "react-native-gesture-handler": "^2.0.0",
    "react-native-reanimated": "^3.0.0",
    "react-native-safe-area-context": "^5.7.0",
    "tsup": "^8.5.0",
    "typescript": "^5.3.0",
    "vitest": "^4.1.2"
  },
  "keywords": [
    "react-native",
    "design-system",
    "design-tokens",
    "theming",
    "layout",
    "ui",
    "flipova",
    "expo"
  ],
  "dependencies": {
    "@craftzdog/react-native-buffer": "^6.0.5",
    "@expo/metro-runtime": "^55.0.9",
    "@expo/vector-icons": "^15.1.1",
    "@react-native-async-storage/async-storage": "~2.1.0",
    "expo": "~55.0.0",
    "expo-router": "~55.0.0",
    "express": "^5.2.1",
    "qrcode": "^1.5.4",
    "react": ">=18.0.0",
    "react-dom": "^19.0.0",
    "react-native": ">=0.73.0",
    "react-native-safe-area-context": ">=4.0.0",
    "react-native-screens": "~4.24.0",
    "react-native-web": "~0.20.0",
    "readable-stream": "^4.5.2",
    "snack-sdk": "^3.8.0",
    "ws": "^8.20.0"
  }
}
