{
  "name": "@flipova/foundation",
  "version": "1.10.1",
  "description": "Design tokens, theming system, and layout primitives for React Native (iOS, Android, Web)",
  "author": "Flipova",
  "license": "MIT",
  "workspaces": [
    ".",
    "studio-v2/packages/*",
    "studio-v2/apps/*"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/flipova/foundation.git"
  },
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./tokens": {
      "types": "./dist/tokens/index.d.ts",
      "import": "./dist/tokens/index.mjs",
      "require": "./dist/tokens/index.js"
    },
    "./theme": {
      "types": "./dist/theme/index.d.ts",
      "import": "./dist/theme/index.mjs",
      "require": "./dist/theme/index.js"
    },
    "./web": {
      "types": "./dist/web/index.d.ts",
      "import": "./dist/web/index.mjs",
      "require": "./dist/web/index.js"
    },
    "./layout": {
      "types": "./dist/layout/index.d.ts",
      "import": "./dist/layout/index.mjs",
      "require": "./dist/layout/index.js"
    },
    "./config": {
      "types": "./dist/config/index.d.ts",
      "import": "./dist/config/index.mjs",
      "require": "./dist/config/index.js"
    },
    "./studio": {
      "require": "./dist/studio-v2/cli/index.js"
    }
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "bin": {
    "flipova-studio": "./dist/studio-v2/cli/index.js"
  },
  "files": [
    "dist",
    "studio-v2/apps/web/dist",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "npm run build:foundation && npm run build:studio-v2",
    "build:foundation": "tsup",
    "build:studio": "cd studio/app && npx expo export --platform web --output-dir dist",
    "build:studio-v2": "cd studio-v2/apps/web && npx expo export --platform web --output-dir dist",
    "dev": "tsup --watch",
    "dev:studio": "cd studio/app && npx expo start --web --port 4201",
    "dev:studio-v2": "cd studio-v2/apps/web && npx expo start --web --port 4202",
    "typecheck": "tsc --noEmit",
    "release": "npm run build && npm run typecheck && changeset publish",
    "version": "changeset version",
    "prepublishOnly": "npm run build && npm run typecheck"
  },
  "peerDependencies": {
    "expo": ">=55.0.0",
    "expo-camera": ">=15.0.0",
    "expo-haptics": ">=13.0.0",
    "expo-linear-gradient": ">=12.0.0",
    "expo-navigation-bar": ">=3.0.0",
    "expo-router": ">=55.0.0",
    "expo-status-bar": ">=2.0.0",
    "lucide-react-native": ">=0.300.0",
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0",
    "react-native": ">=0.73.0",
    "react-native-gesture-handler": ">=2.0.0",
    "react-native-reanimated": ">=3.0.0",
    "react-native-safe-area-context": ">=4.0.0",
    "react-native-screens": ">=4.0.0"
  },
  "peerDependenciesMeta": {
    "expo": {
      "optional": true
    },
    "expo-linear-gradient": {
      "optional": true
    },
    "expo-haptics": {
      "optional": true
    },
    "expo-status-bar": {
      "optional": true
    },
    "expo-navigation-bar": {
      "optional": true
    },
    "expo-router": {
      "optional": true
    },
    "expo-camera": {
      "optional": true
    },
    "react-native": {
      "optional": true
    },
    "react-native-gesture-handler": {
      "optional": true
    },
    "react-native-reanimated": {
      "optional": true
    },
    "react-native-safe-area-context": {
      "optional": true
    },
    "react-native-screens": {
      "optional": true
    },
    "lucide-react-native": {
      "optional": true
    },
    "react-dom": {
      "optional": true
    }
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.6.0",
    "@changesets/cli": "^2.30.0",
    "@craftzdog/react-native-buffer": "^6.1.2",
    "@expo/metro-runtime": "^56.0.15",
    "@expo/vector-icons": "^15.1.1",
    "@react-native-async-storage/async-storage": "^3.1.1",
    "@types/express": "^5.0.6",
    "@types/qrcode": "^1.5.5",
    "@types/react": "^19.0.0",
    "@types/react-native": "^0.73.0",
    "@types/ws": "^8.18.1",
    "expo": "^56.0.11",
    "expo-camera": "^55.0.13",
    "expo-haptics": "^55.0.11",
    "expo-linear-gradient": "^12.0.0",
    "expo-navigation-bar": "^55.0.10",
    "expo-router": "^56.2.10",
    "expo-status-bar": "^55.0.5",
    "fast-check": "^4.6.0",
    "lucide-react-native": "^1.7.0",
    "react-dom": "^19.2.7",
    "react-native": "^0.86.0",
    "react-native-gesture-handler": "^2.0.0",
    "react-native-reanimated": "^3.0.0",
    "react-native-safe-area-context": "^5.8.0",
    "react-native-screens": "^4.25.2",
    "react-native-web": "^0.21.2",
    "readable-stream": "^4.7.0",
    "snack-sdk": "^6.6.2",
    "tsup": "^8.5.0",
    "typescript": "^5.3.0",
    "vitest": "^4.1.2"
  },
  "keywords": [
    "react-native",
    "design-system",
    "design-tokens",
    "theming",
    "layout",
    "ui",
    "flipova",
    "expo"
  ],
  "dependencies": {
    "@radix-ui/react-accordion": "^1.2.0",
    "@radix-ui/react-dropdown-menu": "^2.1.17",
    "@radix-ui/react-slot": "^1.2.5",
    "@radix-ui/react-tabs": "^1.1.14",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "express": "^5.2.1",
    "immer": "^10.1.1",
    "lucide-react": "^1.18.0",
    "motion": "^12.40.0",
    "qrcode": "^1.5.4",
    "react": ">=18.0.0",
    "tailwind-merge": "^3.6.0",
    "ws": "^8.20.0",
    "zustand": "^5.0.5"
  }
}
